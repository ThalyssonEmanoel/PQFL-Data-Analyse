{
  "name": "pqfl-backend",
  "version": "0.1.0",
  "description": "PQFL data analyse backend API (Express + Mongoose).",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "dev": "nodemon server.js",
    "start": "node server.js",
    "db:migrate:create": "migrate-mongo create",
    "db:migrate:up": "migrate-mongo up",
    "db:migrate:down": "migrate-mongo down",
    "seed": "node src/seed/index.js",
    "test": "node --test"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "mongoose": "^8.3.0",
    "morgan": "^1.10.0",
    "pino": "^9.0.0",
    "pino-http": "^10.0.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "migrate-mongo": "^11.0.0",
    "nodemon": "^3.1.0",
    "pino-pretty": "^11.0.0"
  }
}
