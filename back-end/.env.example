# ---------------------------------------------------------------
# Runtime
# ---------------------------------------------------------------
NODE_ENV=development
PORT=3333
API_PREFIX=/api/v1

# ---------------------------------------------------------------
# Database (MongoDB)
# ---------------------------------------------------------------
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=pqfl

# ---------------------------------------------------------------
# Security / CORS
# Comma-separated list of allowed origins. Use "*" for any origin.
# ---------------------------------------------------------------
CORS_ORIGIN=http://localhost:3000

# ---------------------------------------------------------------
# Payload limits
# ---------------------------------------------------------------
JSON_BODY_LIMIT=1mb

# ---------------------------------------------------------------
# Coletum integration (kept for parity with the legacy frontend
# cache. Will be moved to a dedicated service in a later step).
# ---------------------------------------------------------------
COLETUM_FULL_URL=
COLETUM_REQUEST_BUDGET=100
