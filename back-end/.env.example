# ---------------------------------------------------------------
# Runtime
# ---------------------------------------------------------------
NODE_ENV=development
PORT=3333
API_PREFIX=/api/v1

# ---------------------------------------------------------------
# Database (MongoDB)
# ---------------------------------------------------------------
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=pqfl

# ---------------------------------------------------------------
# Security / CORS
# Comma-separated list of allowed origins. Use "*" for any origin.
# ---------------------------------------------------------------
CORS_ORIGIN=http://localhost:3000

# ---------------------------------------------------------------
# Payload limits
# ---------------------------------------------------------------
JSON_BODY_LIMIT=1mb

# ---------------------------------------------------------------
# Coletum API V2 (sync via POST /api/v1/producers/refresh)
# Prefer the structured variables. COLETUM_FULL_URL is kept only
# as a legacy override so we can mirror the existing frontend env.
# ---------------------------------------------------------------
COLETUM_BASE_URL=https://coletum.com/api/webservice/v2
COLETUM_FORM_ID=
COLETUM_TOKEN=
COLETUM_DEFAULT_PAGE_SIZE=100
COLETUM_FULL_URL=
COLETUM_REQUEST_BUDGET=100

# ---------------------------------------------------------------
# Refresh guardrails (Step-5)
# Disable the endpoint in emergencies with REFRESH_ENABLED=false.
# ---------------------------------------------------------------
REFRESH_ENABLED=true
REFRESH_LOCK_TTL_MS=900000
REFRESH_MAX_PAGES_CAP=10000
REFRESH_BULK_CHUNK_SIZE=500
